{
	"interface_version": 2,
	"name": "MaaLYSK",
	"github": "https://github.com/Witty36/MaaLYSK",
	"custom_title": "MaaLYSK | 恋与深空日常/肝活小助手",
	"version": "v0.1.10",
	"icon": "logo.ico",
	"mirrorchyan_rid": "MaaLYSK",
	"mirrorchyan_multiplatform": true,
	"controller": [
		{
			"name": "ADB模拟器",
			"type": "Adb"
		},
		{
			"name": "桌面端",
			"type": "Win32",
			"win32": {
				"class_regex": ".*",
				"window_regex": "Visual Studio"
			}
		}
	],
	"resource": [
		{
			"name": "官服",
			"path": ["{PROJECT_DIR}/resource"]
		}
	],
	"agent_demo": {
		"child_exec": "python",
		"child_args": ["{PROJECT_DIR}/agent/main.py"]
	},
	"task": [
		{
			"name": "=====日常任务=====",
			"entry": "stop"
		},
		{
			"name": "✈️恋与深空启动",
			"entry": "启动游戏版本",
			"default_check": true,
			"option": ["请选择游戏版本", "使用指定账号登录"],
			"description": "目前官服可以成功启动，其他渠道的可能爱莫能助啦\n\n指定账号登录目前仍在画饼中"
		},
		{
			"name": "♻主页面切换账号",
			"entry": "进入主页面切换账号",
			"default_check": false,
			"option": ["游戏版本", "切换后账号"]
		},
		{
			"name": "🍰领日常体力",
			"entry": "进入领体力",
			"default_check": true,
			"description": "中午10:00~14:00，晚上16:00~20:00期间领取~\n\n月卡免费补领"
		},
		{
			"name": "📬领好友体力",
			"entry": "进入领好友体力",
			"default_check": true
		},
		{
			"name": "💫免费思念福利签到",
			"entry": "进入福利签到",
			"default_check": false,
			"description": "[color:orange]当前签到：十日与你——祁煜·驭夜灯阑[/color]\n\n如果有其它活动,第一天记得把其他活动剧情点掉,不然会卡住"
		},
		{
			"name": "💰月卡领取",
			"entry": "进入月卡领取",
			"default_check": false
		},
		{
			"name": "🛍️商城日常领取",
			"entry": "进入商城日常领取",
			"default_check": true
		},
		{
			"name": "🌌星间探测",
			"entry": "进入星间探测",
			"default_check": true,
			"option": ["是否使用加速魔方", "选择探测星系"],
			"description": "目前仅支持自动探测一次银砂星系/辉曜星系,快速探测暂不支持"
		},
		{
			"name": "⚔️日常芯核狩猎",
			"entry": "日常_进入芯核狩猎",
			"default_check": true,
			"description": "自动选择当天开放狩猎的芯核,全部开放时顺序为红绿、黄紫、粉蓝。\n\n支持芯核达到上限时自动前往清理（需提前勾选好低等级自动弃置芯核）。\n\n目前仅支持自动狩猎一次。"
		},
		{
			"name": "⚔️日常追踪豆佬",
			"entry": "日常_进入零点追踪_豆佬",
			"default_check": true,
			"option": ["选择豆佬关卡难度", "选择追踪豆佬次数"],
			"description": "目前可以选择难度1~9，追击1次或10次。"
		},
		{
			"name": "⚔️日常追踪哈特",
			"entry": "日常_进入零点追踪_哈特",
			"default_check": true,
			"option": ["选择哈特关卡难度", "选择追踪哈特次数"],
			"description": "目前可以选择难度1~9，追击至体力耗尽/追击1次或10次。"
		},
		{
			"name": "🍂日常思念升级一次",
			"entry": "进入日常思念升级",
			"default_check": true,
			"description": "消耗一个绿瓶子(10经验值)进行升级以完成每日任务，点进第一张思念找可升级的卡面直到找到为止。\n\n如果卡等级较高或者排序不正确可能会升级四星/三星卡面，介意可关闭此功能。"
		},
		{
			"name": "💞主页面互动",
			"entry": "进入主页面互动",
			"default_check": true
		},
		{
			"name": "📅日常收尾",
			"entry": "进入日常收尾",
			"default_check": true,
			"description": "签到奖励领取,日常任务领取\n\n[color:red]任务完成后,请自行检查是否领取完毕[/color]"
		},
		{
			"name": "💤恋与深空关闭",
			"entry": "关闭游戏"
		},
		{
			"name": "=====周常任务=====",
			"entry": "stop"
		},
		{
			"name": "🛒商城周常领取",
			"entry": "进入商城周常领取",
			"default_check": false,
			"option": ["心砂商店是否购买"],
			"description": "领取每周礼包,快乐小铺的极空许愿券和辉曜磁石"
		},
		{
			"name": "💎年卡领取",
			"entry": "进入年卡领取",
			"default_check": false
		},
		{
			"name": "📷周常拍大头贴",
			"entry": "进入大头贴拍照",
			"default_check": false,
			"option": ["选择大头贴拍照男主"],
			"description": "完成周常拍大头贴的任务"
		},
		{
			"name": "📸周常拍写真",
			"entry": "进入写真拍照",
			"default_check": false,
			"option": ["选择写真拍照男主"],
			"description": "完成周常拍写真的任务"
		},
		{
			"name": "💐周常密约领取",
			"entry": "进入密约",
			"default_check": false,
			"description": "领取密约奖励，密约日程奖励和密约页面奖励都会领掉"
		},
		{
			"name": "🐱周常喵喵牌",
			"entry": "进入喵喵牌",
			"default_check": false,
			"option": ["囤积达上限是否继续"],
			"description": "可选囤积达上限是否继续,如果不继续的话记得检查2400巧克力有没有达到"
		},
		{
			"name": "🎮周常娃娃机",
			"entry": "进入娃娃机",
			"default_check": false,
			"option": [
				"娃娃机模式选择",
				"沈星回抓不抓",
				"黎深抓不抓",
				"祁煜抓不抓",
				"秦彻抓不抓",
				"夏以昼抓不抓"
			],
			"description": "可选秒退和自己抓二爪模式\n\n抓二爪娃娃机目前可顺利运行，遇到男主直接开始抓了会尝试切换成自己抓（点名小鱼！）。\n\n可以自定义二爪娃娃机按钮按下的时长\n\n[color:red]由于模拟器卡顿、娃娃弹跳等情况，不保证每局都抓4-5只，觉得概率低的自行抓取[/color]"
		},
		{
			"name": "🗓️周常收尾",
			"entry": "进入周常收尾",
			"default_check": true,
			"description": "周常任务领取\n\n[color:red]任务完成后,请自行检查是否领取完毕[/color]"
		},
		{
			"name": "=====特色功能=====",
			"entry": "stop"
		},
		{
			"name": "📲自动读短信",
			"entry": "进入自动读短信",
			"default_check": false,
			"option": [
				"沈星回读短信",
				"黎深读短信",
				"祁煜读短信",
				"秦彻读短信",
				"夏以昼读短信"
			],
