	"option": {
		"请选择游戏版本": {
			"type": "select",
			"cases": [
				{
					"name": "恋与深空官服",
					"pipeline_override": {
						"恋与深空官服": {
							"enabled": true
						},
						"sub_启动深空官服": {
							"enabled": true
						}
					}
				}
			]
		},
		"使用指定账号登录": {
			"type": "switch",
			"description": "可只填1-2位连续内容，避开易混淆的字符（如Oo、Ss大小写不分、1lI认错等）",
			"cases": [
				{
					"name": "No",
					"pipeline_override": {
						"切换账号启动": {
							"enabled": false
						}
					}
				},
				{
					"name": "Yes",
					"pipeline_override": {
						"切换账号启动": {
							"enabled": true
						}
					},
					"option": ["账号前3位"]
				}
			]
		},
		"游戏版本": {
			"type": "select",
			"cases": [
				{
					"name": "恋与深空官服",
					"pipeline_override": {
						"恋与深空官服": {
							"enabled": true
						},
						"sub_启动深空官服": {
							"enabled": true
						}
					}
				}
			]
		},
		"切换后账号": {
			"type": "input",
			"inputs": [
				{
					"name": "account",
					"description": "可只填1-2位连续内容，避开易混淆的字符（如Oo、Ss大小写不分、1lI认错等）",
					"label": "帐号前3位中的任意内容",
					"pipeline_type": "string",
					"default": "xxx"
				}
			],
			"pipeline_override": {
				"选择登录账号": {
					"expected": ["{account}"]
				}
			}
		},
		"账号前3位": {
			"type": "input",
			"inputs": [
				{
					"name": "account",
					"label": "帐号前3位中的任意内容",
					"pipeline_type": "string",
					"default": "xxx"
				}
			],
			"pipeline_override": {
				"选择登录账号": {
					"expected": ["{account}"]
				}
			}
		},
		"新账号前3位": {
			"type": "input",
			"inputs": [
				{
					"name": "account",
					"label": "新帐号前3位中的任意内容",
					"pipeline_type": "string",
					"default": "xxx"
				}
			],
			"pipeline_override": {
				"选择登录账号": {
					"expected": ["{account}"]
				}
			}
		},
		"是否使用加速魔方": {
			"type": "switch",
			"cases": [
				{
					"name": "No",
					"pipeline_override": {
						"是否探测中": {
							"next": ["stop"]
						}
					}
				},
				{
					"name": "Yes",
					"pipeline_override": {
						"是否探测中": {
							"next": ["结束探测"]
						}
					}
				}
