{
	"task": [
		{
			"name": "✈️恋与深空启动",
			"entry": "启动游戏版本",
			"controller": ["ADB模拟器"],
			"default_check": true,
			"option": ["请选择游戏版本", "使用指定账号登录"],
			"description": "目前官服可以成功启动，其他渠道的需要反馈区服\n\n不支持PlayCover，仅支持ADB模拟器"
		},
		{
			"name": "♻主页面切换账号",
			"entry": "进入主页面切换账号",
			"default_check": false,
			"option": ["游戏版本", "账号前3位"]
		}
	],
	"option": {
		"请选择游戏版本": {
			"type": "select",
			"cases": [
				{
					"name": "恋与深空官服",
					"pipeline_override": {
						"恋与深空官服": {
							"enabled": true
						},
						"sub_启动深空官服": {
							"enabled": true
						}
					}
				}
			]
		},
		"使用指定账号登录": {
			"type": "switch",
			"description": "可只填1-2位连续内容，避开易混淆的字符（如Oo、Ss大小写不分、1lI认错等）",
			"cases": [
				{
					"name": "No",
					"pipeline_override": {
						"切换账号启动": {
							"enabled": false
						}
					}
				},
				{
					"name": "Yes",
					"pipeline_override": {
						"切换账号启动": {
							"enabled": true
						}
					},
					"option": ["账号前3位"]
				}
			]
		},
		"游戏版本": {
			"type": "select",
			"cases": [
				{
					"name": "恋与深空官服",
					"pipeline_override": {
						"恋与深空官服": {
							"enabled": true
						},
						"sub_启动深空官服": {
							"enabled": true
						}
					}
				}
			]
		},
		"账号前3位": {
			"type": "input",
			"inputs": [
				{
					"name": "account",
					"description": "可只填1-2位连续内容，避开易混淆的字符（如Oo、Ss大小写不分、1lI认错等）",
					"label": "帐号前3位中的任意内容",
					"pipeline_type": "string",
					"default": "xxx"
				}
			],
			"pipeline_override": {
				"选择登录账号": {
					"expected": ["{account}"],
					"focus": {
						"Node.Action.Succeeded": "登录账号：{account}"
					}
				}
			}
		}
	}
}
