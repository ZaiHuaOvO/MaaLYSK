						"芯核是否解锁": {
							"next": ["芯核自动追击10次"]
						}
					}
				},
				{
					"name": "追击至体力耗尽",
					"pipeline_override": {
						"芯核是否解锁": {
							"next": ["芯核自动追击耗尽"]
						}
					}
				}
			]
		},
		"选择日常芯核狩猎颜色顺序": {
			"type": "select",
			"label": "选择芯核颜色顺序",
