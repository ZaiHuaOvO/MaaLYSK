							]
						}
					}
				},
				{
					"name": "黄紫芯核",
					"pipeline_override": {
						"芯核狩猎主页面确认": {
							"next": [
								"日常_选择黄紫芯核",
								"日常_选择红绿芯核",
								"日常_选择粉蓝芯核"
							]
						}
					}
				},
				{
					"name": "粉蓝芯核",
					"pipeline_override": {
						"芯核狩猎主页面确认": {
